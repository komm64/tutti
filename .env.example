# Local-only secrets for dev / test scripts.
#
# 使い方:
#   1. このファイルを `.env` (または `.env.local`) としてコピー
#   2. 値を埋める
#   3. .env / .env.local は .gitignore 済なのでコミットされない
#
# Node 20+ なら `node --env-file=.env scripts/foo.mjs` で読み込める。
# それ以外は手動で `TEST_EMAIL=foo@bar.com node scripts/foo.mjs` のように渡す。

# テスト用 Google アカウントのメールアドレス
# (scripts/click-google-account-v2.mjs などで使う)
TEST_EMAIL=

# ── Cloudflare Workers proxy (worker/) 用 ──────────────────────────────
# 拡張のエラー報告を GitHub Issues に転送する worker をデプロイする時に使う。

# Cloudflare API token (https://dash.cloudflare.com/profile/api-tokens)
# Permissions: Workers Scripts:Edit + Workers KV Storage:Edit
CLOUDFLARE_API_TOKEN=

# GitHub PAT (Fine-grained, repo komm64/tutti, Issues: read+write)。
# worker の secret に登録するもの。Tutti 本体には含めない。
GITHUB_TOKEN_FOR_WORKER=
