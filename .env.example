# Local-only secrets for dev / test scripts.
#
# 使い方:
#   1. このファイルを `.env` (または `.env.local`) としてコピー
#   2. 値を埋める
#   3. .env / .env.local は .gitignore 済なのでコミットされない
#
# Node 20+ なら `node --env-file=.env scripts/foo.mjs` で読み込める。
# それ以外は手動で `TEST_EMAIL=foo@bar.com node scripts/foo.mjs` のように渡す。
#
# **大半のユーザは何も埋めなくて OK** (`npm run dev` には不要)。
# 下のセクション分けに従って、必要なものだけ書いてください。

# ────────────────────────────────────────────────────────────────────────
# [一般 dev / contributor 向け] テストスクリプト用
# ────────────────────────────────────────────────────────────────────────

# テスト用 Google アカウントのメールアドレス
# (scripts/click-google-account-v2.mjs などで使う)
TEST_EMAIL=

# ────────────────────────────────────────────────────────────────────────
# [owner-only] komm64 が運用インフラを操作する時だけ必要 (= 通常 contributor は不要)
# ────────────────────────────────────────────────────────────────────────

# --- Cloudflare Workers proxy (worker/) のデプロイ用 ---
# 拡張のエラー報告を GitHub Issues に転送する worker をデプロイする時に使う。
# Permissions: Workers Scripts:Edit + Workers KV Storage:Edit
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# --- worker から komm64/tutti-issues に issue を作るための GitHub PAT ---
# Fine-grained, repo komm64/tutti-issues only, Issues: read+write。
# worker の wrangler secret として登録する。Tutti 本体には含めない。
GITHUB_TOKEN_FOR_WORKER=

# --- Chrome Web Store Publish API (scripts/cws/) ---
# 拡張本体の publish / status polling を自動化するための OAuth credentials。
# https://console.cloud.google.com/auth/clients で Desktop app type で発行。
# Item ID は CWS Developer Dashboard の URL に含まれる文字列。
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_ITEM_ID=
# 初回 OAuth flow (`node scripts/cws/auth.mjs`) で取得して埋める
CWS_REFRESH_TOKEN=
