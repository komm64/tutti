# Dependencies
node_modules/

# WXT build artifacts
.output/
.wxt/

# Logs
*.log
npm-debug.log*

# OS cruft
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Internal notes (kept in komm64/tutti-archive only)
CLAUDE.md
CONCEPT.md
audit-checklist.md
release-procedure.md
submission-guide.md

# Test scripts artifacts (screenshots from puppeteer probes)
scripts/*.png
# Brave launch helper (dev-machine specific paths)
scripts/launch-test-brave.cmd
# Chrome launch helper (dev-machine specific paths; 内部 path も書かれる)
scripts/launch-test-chrome.bat

# Browser test profiles (Chrome / Brave の user-data-dir、~数 GB)
test-data/

# E2E test fixtures (image / video の binary。各自 local で用意)
scripts/e2e/fixtures/*
!scripts/e2e/fixtures/README.md

# Local scratch / brainstorm notes
tmp/

# Local secrets (test account email, etc.). Use .env.example as template.
.env
.env.local
.env.*.local

# Claude Code session state (cron lock 等、commit しない)
.claude/

# ffmpeg.wasm runtime (postinstall + prebuild で node_modules からコピー)
public/ffmpeg/
.tmp
