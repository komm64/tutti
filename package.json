{
  "name": "tutti",
  "version": "0.5.25",
  "description": "クロスポストの面倒を全部肩代わりする Chrome 拡張",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-chrome-locales.mjs && wxt",
    "dev:firefox": "node scripts/build-chrome-locales.mjs && wxt -b firefox",
    "build": "node scripts/patch-ffmpeg-package.mjs && node scripts/copy-ffmpeg.mjs && node scripts/build-chrome-locales.mjs && wxt build && node scripts/patch-ffmpeg-worker.mjs && node scripts/clean-chrome-locales.mjs",
    "build:firefox": "node scripts/copy-ffmpeg.mjs && node scripts/build-chrome-locales.mjs && wxt build -b firefox && node scripts/clean-chrome-locales.mjs",
    "zip": "npm run build && node scripts/zip-extension.mjs",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e-api": "vitest run --config vitest.config.e2e-api.ts",
    "e2e": "node scripts/e2e/run.mjs",
    "e2e:smoke": "npm run build && node scripts/e2e/mock-browser-smoke.mjs",
    "e2e:smoke:no-build": "node scripts/e2e/mock-browser-smoke.mjs",
    "e2e:video-smoke": "npm run build && node scripts/e2e/video-conversion-smoke.mjs",
    "e2e:video-smoke:no-build": "node scripts/e2e/video-conversion-smoke.mjs",
    "postinstall": "wxt prepare && node scripts/patch-ffmpeg-package.mjs && node scripts/copy-ffmpeg.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komm64/tutti.git"
  },
  "author": "komm64",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/komm64/tutti/issues"
  },
  "homepage": "https://github.com/komm64/tutti#readme",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.40",
    "@vitest/ui": "^4.1.5",
    "@wxt-dev/module-svelte": "^2.0.5",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "puppeteer-core": "^24.42.0",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wxt": "^0.20.25"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/core-mt": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "mediabunny": "^1.46.0"
  }
}
